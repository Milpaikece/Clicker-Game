import pygame
import time
from random import randint
pygame.init()


"membuat jendela program"
back = (87, 87, 247) #warna latar belakang
mw = pygame.display.set_mode((500, 500)) #jendela utama
mw.fill(back)
clock = pygame.time.Clock()

"kelas segiempat"
class Area():
    #Konstruktor kelas Area dengan parameter posisi (x, y), ukuran (width, height), dan warna awal (color).
  def __init__(self, x=0, y=0, width=10, height=10, color=None): 
      self.rect = pygame.Rect(x, y, width, height) #membuat objek rect = segiempat
      self.fill_color = color #menyimpan warna isi segiempat ke atribut fill_color.
    #Method untuk mengubah warna segiempat.
  def color(self, new_color):
      self.fill_color = new_color
    #Mengganti warna isi segiempat dengan warna baru
  def fill(self):
      pygame.draw.rect(mw, self.fill_color, self.rect) #Menggambar segiempat berisi warna (fill) pada jendela.
    #Untuk menggambar garis tepi (outline) segiempat.
  def outline(self, frame_color, thickness):
      pygame.draw.rect(mw, frame_color, self.rect, thickness)
  def collidepoint(self, x, y):
      return self.rect.collidepoint(x, y)

class Label(Area):
    #mengatur font, ukuran font, warna
    def set_text(self, text, text_size, text_color=(255,51,153)):
        self.image = pygame.font.SysFont('verdana', text_size).render(text, True, text_color)
    #menggambar tulisan ke dalam rect, shift_x dan y itu koordinat untuk mengatur posisi text
    def draw(self, shift_x=0, shift_y=0):
      self.fill()
      mw.blit(self.image, (self.rect.x + shift_x, self.rect.y + shift_y)) # #mengubah text ke gambar

light_purple = (87, 228, 247)
soft_pink = (87, 247, 204)
Hejo = (0, 255, 0)
Bereum = (255, 0, 0)
biru_bahlil = (64, 247, 247)

time_text = Label(0,0,100,50,back)
time_text.set_text('Time:',40, biru_bahlil)
time_text.draw(20, 20)

timer = Label(20,55,50,40,back)
timer.set_text('00:00', 40, biru_bahlil)
timer.draw(0,0)


time_text = Label(390,0,100,50,back)
time_text.set_text('Point:',40, biru_bahlil)
time_text.draw(20, 20)

timer = Label(440,55,50,40,back)
timer.set_text('0', 40, biru_bahlil)
timer.draw(0,0)


#membuat list kartu kosong
cards = []
num_cards = 4
x = 70 #jarak kartu pertama dari ujung kiri
for i in range(num_cards):
    new_card = Label(x, 150, 70, 100, light_purple)
    new_card.outline(soft_pink, 10) #atur warna outline kartu
    new_card.set_text('CLICK', 25) #atur teks dan ukuran
    cards.append(new_card)
    x = x + 100 #untuk memberikan jarak antar kartu

wait = 0 #variabel untuk menahan tulisan klik tetap berada di kartu dalam waktu

while True:
    if wait == 0:
        #memindahkan label
        wait = 1 #untuk menahan tulisan click
        click = randint(1, num_cards)
        for i in range(num_cards):
            cards[i].color((255,255,0))
            if (i + 1) == click:
                cards[i].draw(10, 40)
            else:
                cards[i].fill()
    else:
        wait -= 1

    for event in pygame.event.get():
        if event.type == pygame.MOUSEBUTTONDOWN and event.button == 1:
            x, y = event.pos
            for i in range(num_cards):
                if cards[i].collidepoint(x,y):
                    if i + 1 == click:
                        cards[i].color(Hejo)
                    else:
                        cards[i].color(Bereum)

                    cards[i].fill()

    pygame.display.update()
    clock.tick(40)
